# =============================================================
#  Roostoo Trading Bot — environment variable template
#
#  1. Copy this file:   cp .env.example .env
#  2. Fill in real values below.
#  3. NEVER commit .env to version control (add it to .gitignore).
# =============================================================

# ---------------------------
# Roostoo API credentials  (required)
# ---------------------------
ROOSTOO_API_KEY=your_api_key_here
ROOSTOO_API_SECRET=your_api_secret_here

# Roostoo base URL  (required)
ROOSTOO_BASE_URL=https://mock.roostoo.com

# ---------------------------
# Research database path
# ---------------------------
DUCKDB_PATH=data/research.duckdb

# ---------------------------
# Optional overrides
# ---------------------------
# Log verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO
